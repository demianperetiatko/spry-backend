# Application Configuration
APP_NAME="Spry Backend v2"
APP_VERSION=2.0.0
APP_ENV=dev
DEBUG=true

# Server Configuration
HOST=0.0.0.0
PORT=8000

# Database Configuration
DATABASE_URL=postgresql+asyncpg://spry:spry_pwd@localhost:5432/spry_v2

# Security
SECRET_KEY=your-secret-key-here-change-in-production

# CORS Configuration
CORS_ORIGINS=http://localhost:3000,https://app.spryplan.com,https://dev-app.spryplan.com

# Email Configuration (Mailjet)
MAILJET_API_KEY=your-mailjet-api-key
MAILJET_SECRET_KEY=your-mailjet-secret-key

# Google OAuth Configuration
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_REDIRECT_URI=https://dev-api.spryplan.com/auth/callback/google/

# Google Cloud Platform Configuration
GCP_SERVICE_KEY_PATH=gcp_service_account.json
GCP_BUCKET_NAME=app-spryplan-bucket
GCP_DEFAULT_UPLOAD_PREFIX=image/profile/
DEMO_GOOGLE_ACCOUNT_SERVICE_FOLDER=demo_google_account_service_key

# Frontend Configuration
FRONTEND_DOMAIN=https://dev-app.spryplan.com

# Backend Configuration
BACKEND_DOMAIN=https://dev-api.spryplan.com

# Invitation Configuration
INVITATION_API_PREFIX=/invitations
FRONTEND_INVITATION_ACCEPTED_REDIRECT=/login

# Admin API Configuration
ADMIN_API_KEY=your-admin-api-key-here